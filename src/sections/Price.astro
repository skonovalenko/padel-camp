---
import SectionTag from '../components/ui/SectionTag.astro';
import PriceItem from '../components/PriceItem.astro';
import Button from '../components/ui/Button.astro';
import { priceWithout, priceWith } from '../data/pricing';
---
<section id="price" class="px-[24px] md:px-[70px] py-[24px] w-full relative overflow-hidden">

  <div class="flex flex-col gap-[24px] items-center px-0 md:px-[30px]">
    <!-- Header -->
    <div class="flex flex-col items-center" data-animate="fade-up">
      <div class="mb-1">
        <SectionTag label="вартість" />
      </div>
      <h2 class="font-inter font-semibold text-[32px] md:text-[64px] text-main text-center leading-normal">
        Обери свій формат
      </h2>
    </div>

    <!-- Pricing cards -->
    <div class="bg-main border-4 border-main rounded-[24px]
                shadow-[0px_4px_24px_0px_rgba(0,0,0,0.25)]
                flex flex-col md:flex-row w-full">

      <!-- Without accommodation -->
      <div data-animate="slide-left" class="flex-1 flex flex-col items-center justify-center
                  px-[36px] md:px-[70px] py-[24px] md:pt-[30px] md:pb-[40px]
                  rounded-[24px]">
        <div class="flex flex-col gap-[12px] md:gap-[24px] items-start w-full">
          <h3 class="font-inter font-semibold text-[16px] md:text-[28px] text-white text-center w-full">
            Без проживання
          </h3>
          <div class="w-full flex justify-center">
            <span class="font-inter font-semibold text-[36px] md:text-[64px] text-white leading-[36px] md:leading-[64px]">€350</span>
          </div>
          <ul class="flex flex-col gap-[8px] w-full">
            {priceWithout.map((item) => (
              <PriceItem text={item.text} included={item.included} />
            ))}
          </ul>
        </div>
      </div>

      <!-- With accommodation -->
      <div data-animate="slide-right" data-delay="100" class="flex-1 bg-white rounded-[24px]
                  shadow-[0px_-4px_16px_0px_rgba(0,0,0,0.25)]
                  flex flex-col items-center justify-center
                  px-[36px] md:px-[70px] py-[24px] md:pt-[30px] md:pb-[40px]">
        <div class="flex flex-col gap-[12px] md:gap-[24px] items-start w-full">
          <h3 class="font-inter font-semibold text-[16px] md:text-[28px] text-main text-center w-full">
            З проживанням
          </h3>
          <div class="w-full flex justify-center">
            <span class="font-inter font-semibold text-[36px] md:text-[64px] text-action leading-[36px] md:leading-[64px]">€750</span>
          </div>
          <ul class="flex flex-col gap-[8px] w-full">
            {priceWith.map((item) => (
              <PriceItem text={item.text} included={item.included} variant="light" />
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="flex flex-col items-center gap-[5px]" data-animate="fade-up" data-delay="200">
      <Button href="#contact" text="Забронювати" />
      <p class="font-inter font-normal text-[8px] md:text-[12px] text-main text-center">
        *Доступно лише 12 місць
      </p>
    </div>
  </div>
</section>
